<Window x:Class="RefugeAnimaux.couchePresentation.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Refuge d'animaux" Height="760" Width="1180"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MainWindowStyle}">
    <DockPanel Margin="14">
        <Border DockPanel.Dock="Bottom" Padding="10" Background="#EEF6FF" BorderBrush="#D5E2EE" BorderThickness="1" CornerRadius="6" Margin="0,10,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Content="Rafraîchir"
                        Command="{Binding RafraichirCommand}"
                        Width="180"
                        Margin="0,0,12,0"
                        ToolTip="Recharge les données depuis la base"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <TabControl Background="Transparent">
            <TabItem Header="Personnes de contact">
                <Grid Margin="8" Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#FFFFFF">
                        <StackPanel>
                            <TextBlock Text="Ajouter une personne" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Label Content="Nom"/>
                            <TextBox Text="{Binding ContactNom, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Prénom"/>
                            <TextBox Text="{Binding ContactPrenom, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Registre national (yy.mm.dd-999.99)"/>
                            <TextBox Text="{Binding ContactRegistreNational, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Rue"/>
                            <TextBox Text="{Binding ContactRue, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Code postal"/>
                            <TextBox Text="{Binding ContactCp, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Localité"/>
                            <TextBox Text="{Binding ContactLocalite, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Au moins un moyen de contact est obligatoire : GSM, téléphone ou email."
                                       TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,8,8"/>
                            <Label Content="GSM"/>
                            <TextBox Text="{Binding ContactGsm, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Téléphone"/>
                            <TextBox Text="{Binding ContactTelephone, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Email"/>
                            <TextBox Text="{Binding ContactEmail, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Rôles" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <CheckBox Content="Bénévole" IsChecked="{Binding RoleBenevole}"/>
                            <CheckBox Content="Adoptant" IsChecked="{Binding RoleAdoptant}"/>
                            <CheckBox Content="Candidat" IsChecked="{Binding RoleCandidat}"/>
                            <CheckBox Content="Famille d'accueil" IsChecked="{Binding RoleFamilleAccueil}"/>

                            <TextBlock Text="{Binding ContactErrorMessage}" Style="{StaticResource ErrorTextStyle}"/>

                            <Button Content="Ajouter le contact" Command="{Binding AjouterContactCommand}" IsEnabled="{Binding PeutAjouterContact}"/>
                            <Button Content="Nouveau contact" Command="{Binding NouveauContactCommand}"/>
                            <Button Content="Modifier le contact sélectionné" Command="{Binding ModifierContactCommand}"/>
                            <Button Content="Supprimer le contact sélectionné" Command="{Binding SupprimerContactCommand}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <DataGrid Grid.Column="1" ItemsSource="{Binding Contacts}" SelectedItem="{Binding ContactSelectionne}" Margin="14,0,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding IdContact}" Width="Auto"/>
                            <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="Auto"/>
                            <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="Auto"/>
                            <DataGridTextColumn Header="Rôles" Binding="{Binding RolesAffichage}" Width="Auto"/>
                            <DataGridTextColumn Header="GSM" Binding="{Binding GSM}" Width="Auto"/>
                            <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="Auto"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Animaux">
                <Grid Margin="8" Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#FFFFFF">
                        <StackPanel>
                            <TextBlock Text="Ajouter un animal" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Label Content="Date d'entrée"/>
                            <DatePicker SelectedDate="{Binding DateEntreeAnimal}"/>
                            <Label Content="Nom"/>
                            <TextBox Text="{Binding AnimalNom, UpdateSourceTrigger=PropertyChanged}"/>
                            <Label Content="Type"/>
                            <ComboBox ItemsSource="{Binding TypesAnimal}" SelectedItem="{Binding TypeAnimalSelectionne}" ItemTemplate="{StaticResource EnumComboTemplate}"/>
                            <Label Content="Sexe"/>
                            <ComboBox ItemsSource="{Binding Sexes}" SelectedItem="{Binding SexeSelectionne}" ItemTemplate="{StaticResource EnumComboTemplate}"/>
                            <Label Content="Date de naissance"/>
                            <DatePicker SelectedDate="{Binding DateNaissanceAnimal}"/>
                            <CheckBox Content="Animal stérilisé" IsChecked="{Binding AnimalSterilise}" Margin="0,8,0,8"/>
                            <Label Content="Date de stérilisation"/>
                            <DatePicker SelectedDate="{Binding DateSterilisationAnimal}" IsEnabled="{Binding AnimalSterilise}"/>
                            <Label Content="Description"/>
                            <TextBox Text="{Binding AnimalDescription, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="55"/>
                            <Label Content="Particularités"/>
                            <TextBox Text="{Binding AnimalParticularites, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="55"/>
                            <Label Content="Couleurs (séparées par virgule ou retour ligne)"/>
                            <TextBox Text="{Binding AnimalCouleurs, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="65"/>
                            <Label Content="Motif d'entrée"/>
                            <ComboBox ItemsSource="{Binding MotifsEntree}" SelectedItem="{Binding MotifEntreeSelectionne}" DisplayMemberPath="LibelleAffichage"/>
                            <Label Content="Contact d'entrée"/>
                            <ComboBox ItemsSource="{Binding Contacts}" SelectedItem="{Binding ContactEntreeSelectionne}" DisplayMemberPath="NomComplet"/>
                            <TextBlock Text="{Binding AnimalErrorMessage}" Style="{StaticResource ErrorTextStyle}"/>

                            <Button Content="Ajouter l'animal" Command="{Binding AjouterAnimalCommand}" IsEnabled="{Binding PeutAjouterAnimal}"/>
                            <Button Content="Nouvel animal" Command="{Binding NouvelAnimalCommand}"/>
                            <Button Content="Modifier l'animal sélectionné" Command="{Binding ModifierAnimalCommand}"/>
                            <Button Content="Supprimer l'animal sélectionné" Command="{Binding SupprimerAnimalCommand}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <TabControl Grid.Column="1" Margin="14,0,0,0" Background="#FFFFFF">
                        <TabItem Header="Présents au refuge">
                            <DataGrid ItemsSource="{Binding AnimauxPresents}" SelectedItem="{Binding AnimalGestionSelectionne}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding IdAnimal}" Width="Auto"/>
                                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="Auto"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding TypeTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Sexe" Binding="{Binding SexeTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Entrée" Binding="{Binding DateEntree, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                    <DataGridTextColumn Header="Motif entrée" Binding="{Binding MotifEntreeTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Contact" Binding="{Binding ContactEntree}" Width="Auto"/>
                                    <DataGridTextColumn Header="Naissance" Binding="{Binding DateNaissance, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                    <DataGridTextColumn Header="Stérilisé" Binding="{Binding SteriliseTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Date stérilisation" Binding="{Binding DateSterilisation, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                    <DataGridTextColumn Header="Couleurs" Binding="{Binding CouleursTexte}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Historique complet">
                            <DataGrid ItemsSource="{Binding TousLesAnimaux}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding IdAnimal}" Width="Auto"/>
                                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="Auto"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding TypeTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Sexe" Binding="{Binding SexeTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Entrée" Binding="{Binding DateEntree, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                    <DataGridTextColumn Header="Motif entrée" Binding="{Binding MotifEntreeTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Contact entrée" Binding="{Binding ContactEntree}" Width="Auto"/>
                                    <DataGridTextColumn Header="Sortie" Binding="{Binding DateSortie, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                    <DataGridTextColumn Header="Motif sortie" Binding="{Binding MotifSortieTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Contact sortie" Binding="{Binding ContactSortie}" Width="Auto"/>
                                    <DataGridTextColumn Header="Naissance" Binding="{Binding DateNaissance, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                    <DataGridTextColumn Header="Stérilisé" Binding="{Binding SteriliseTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Date stérilisation" Binding="{Binding DateSterilisation, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                    <DataGridTextColumn Header="Décès" Binding="{Binding DateDeces, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                    <DataGridTextColumn Header="Couleurs" Binding="{Binding CouleursTexte}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Gestion animal">
                            <Grid Margin="8" Background="White">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="330"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#FFFFFF">
                                    <StackPanel>
                                        <TextBlock Text="Animal à gérer" FontSize="16" FontWeight="Bold"/>
                                        <ComboBox ItemsSource="{Binding AnimauxPresents}" SelectedItem="{Binding AnimalGestionSelectionne}" DisplayMemberPath="NomAvecId"/>
                                        <Button Content="Charger les détails" Command="{Binding ChargerDetailsAnimalCommand}"/>

                                        <TextBlock Text="Compatibilités" FontSize="16" FontWeight="Bold" Margin="0,12,0,4"/>
                                        <Label Content="Type"/>
                                        <ComboBox ItemsSource="{Binding TypesCompatibilite}" SelectedItem="{Binding TypeCompatibiliteSelectionne}" ItemTemplate="{StaticResource EnumComboTemplate}"/>
                                        <Label Content="Valeur"/>
                                        <ComboBox ItemsSource="{Binding ValeursCompatibilite}" SelectedItem="{Binding ValeurCompatibiliteSelectionnee}" ItemTemplate="{StaticResource EnumComboTemplate}"/>
                                        <Label Content="Description"/>
                                        <TextBox Text="{Binding DescriptionCompatibilite, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="60"/>
                                        <TextBlock Text="{Binding AnimalGestionErrorMessage}" Style="{StaticResource ErrorTextStyle}"/>
                                        <Button Content="Ajouter la compatibilité" Command="{Binding AjouterCompatibiliteCommand}"/>

                                        <TextBlock Text="Sortie du refuge" FontWeight="SemiBold" Margin="0,12,0,4"/>
                                        <ComboBox ItemsSource="{Binding AnimauxPresents}" SelectedItem="{Binding AnimalSortieSelectionne}" DisplayMemberPath="NomAvecId"/>
                                        <DatePicker SelectedDate="{Binding DateSortieAnimal}"/>
                                        <ComboBox ItemsSource="{Binding MotifsSortie}" SelectedItem="{Binding MotifSortieSelectionne}" DisplayMemberPath="LibelleAffichage"/>
                                        <ComboBox ItemsSource="{Binding Contacts}" SelectedItem="{Binding ContactSortieSelectionne}" DisplayMemberPath="NomComplet"/>
                                        <Button Content="Enregistrer la sortie" Command="{Binding EnregistrerSortieCommand}"/>
                                    </StackPanel>
                                </ScrollViewer>

                                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                                    <TextBlock Text="Compatibilités" FontSize="16" FontWeight="Bold"/>
                                    <DataGrid ItemsSource="{Binding CompatibilitesAnimal}" SelectedItem="{Binding CompatibiliteSelectionnee}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Id" Binding="{Binding IdCompat}" Width="Auto"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding TypeTexte}" Width="Auto"/>
                                            <DataGridTextColumn Header="Valeur" Binding="{Binding ValeurTexte}" Width="Auto"/>
                                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Button Content="Supprimer la compatibilité sélectionnée" Command="{Binding SupprimerCompatibiliteCommand}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <TabItem Header="Adoptions">
                <Grid Margin="8" Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Background="#FFFFFF" Margin="4">
                        <TextBlock Text="Nouvelle demande" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Label Content="Animal présent au refuge"/>
                        <ComboBox ItemsSource="{Binding AnimauxPresents}" SelectedItem="{Binding AnimalAdoptionSelectionne}" DisplayMemberPath="NomAvecId"/>
                        <Label Content="Contact candidat"/>
                        <ComboBox ItemsSource="{Binding Contacts}" SelectedItem="{Binding ContactAdoptionSelectionne}" DisplayMemberPath="NomComplet"/>
                        <Label Content="Date de demande"/>
                        <DatePicker SelectedDate="{Binding DateDemandeAdoption}"/>
                        <TextBlock Text="{Binding AdoptionErrorMessage}" Style="{StaticResource ErrorTextStyle}"/>
                        <Button Content="Créer la demande" Command="{Binding AjouterAdoptionCommand}" Margin="0,12,8,20"/>

                        <TextBlock Text="Modifier un statut" FontSize="18" FontWeight="Bold" Margin="0,12,0,10"/>
                        <Label Content="Nouveau statut"/>
                        <ComboBox ItemsSource="{Binding StatutsAdoption}" SelectedItem="{Binding NouveauStatutAdoption}" ItemTemplate="{StaticResource EnumComboTemplate}"/>
                        <Label Content="Date de changement de statut"/>
                        <DatePicker SelectedDate="{Binding DateChangementStatutAdoption}"/>
                        <Button Content="Appliquer au dossier sélectionné" Command="{Binding ModifierStatutAdoptionCommand}" Margin="0,12,8,0"/>
                        <TextBlock Text="Quand le statut passe à acceptee, une sortie du refuge avec motif adoption est créée automatiquement. Si une adoption acceptee est ensuite rejetée, l'animal revient au refuge."
                                   TextWrapping="Wrap" Margin="0,12,8,0"/>
                    </StackPanel>

                    <DataGrid Grid.Column="1" ItemsSource="{Binding Adoptions}" SelectedItem="{Binding AdoptionSelectionnee}" Margin="14,0,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding IdAdoption}" Width="Auto"/>
                            <DataGridTextColumn Header="Animal" Binding="{Binding NomAnimal}" Width="Auto"/>
                            <DataGridTextColumn Header="Id animal" Binding="{Binding IdAnimal}" Width="Auto"/>
                            <DataGridTextColumn Header="Contact" Binding="{Binding ContactTexte}" Width="Auto"/>
                            <DataGridTextColumn Header="Date demande" Binding="{Binding DateDemande, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                            <DataGridTextColumn Header="Statut" Binding="{Binding StatutTexte}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Familles d'accueil">
                <Grid Margin="8" Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Background="#FFFFFF" Margin="4">
                        <TextBlock Text="Ajouter un accueil" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Label Content="Animal présent au refuge"/>
                        <ComboBox ItemsSource="{Binding AnimauxPresents}" SelectedItem="{Binding AnimalAccueilSelectionne}" DisplayMemberPath="NomAvecId"/>
                        <Label Content="Famille d'accueil"/>
                        <ComboBox ItemsSource="{Binding Contacts}" SelectedItem="{Binding ContactAccueilSelectionne}" DisplayMemberPath="NomComplet"/>
                        <Label Content="Date de début"/>
                        <DatePicker SelectedDate="{Binding DateDebutAccueil}"/>
                        <Label Content="Date de fin (vide si en cours)"/>
                        <DatePicker SelectedDate="{Binding DateFinAccueil}"/>
                        <TextBlock Text="{Binding AccueilErrorMessage}" Style="{StaticResource ErrorTextStyle}"/>

                        <Button Content="Ajouter l'accueil" Command="{Binding AjouterAccueilCommand}" Margin="0,12,8,20"/>

                        <TextBlock Text="Modifier un accueil" FontSize="18" FontWeight="Bold" Margin="0,12,0,10"/>
                        <Label Content="Date de fin de l'accueil sélectionné"/>
                        <DatePicker SelectedDate="{Binding DateFinModificationAccueil}"/>
                        <Button Content="Enregistrer la date de fin" Command="{Binding ModifierAccueilCommand}" Margin="0,12,8,20"/>

                        <TextBlock Text="Listes" FontSize="18" FontWeight="Bold" Margin="0,12,0,10"/>
                        <Label Content="Animaux accueillis par une famille"/>
                        <ComboBox ItemsSource="{Binding ContactsAvecAccueil}" SelectedItem="{Binding ContactAccueilListeSelectionne}" DisplayMemberPath="NomComplet"/>
                        <Label Content="Accueils d'un animal"/>
                        <ComboBox ItemsSource="{Binding AnimauxAvecAccueil}" SelectedItem="{Binding AnimalAccueilListeSelectionne}" DisplayMemberPath="NomAvecId"/>
                        <Button Content="Charger les listes" Command="{Binding ChargerAccueilsCommand}" Margin="0,12,8,0"/>
                    </StackPanel>

                    <TabControl Grid.Column="1" Margin="14,0,0,0" Background="#FFFFFF">
                        <TabItem Header="Par famille">
                            <DataGrid ItemsSource="{Binding AccueilsParFamille}" SelectedItem="{Binding AccueilSelectionne}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding IdAccueil}" Width="Auto"/>
                                    <DataGridTextColumn Header="Période" Binding="{Binding PeriodeTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Id animal" Binding="{Binding IdAnimal}" Width="Auto"/>
                                    <DataGridTextColumn Header="Animal" Binding="{Binding NomAnimal}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Par animal">
                            <DataGrid ItemsSource="{Binding AccueilsParAnimal}" SelectedItem="{Binding AccueilSelectionne}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding IdAccueil}" Width="Auto"/>
                                    <DataGridTextColumn Header="Période" Binding="{Binding PeriodeTexte}" Width="Auto"/>
                                    <DataGridTextColumn Header="Id animal" Binding="{Binding IdAnimal}" Width="Auto"/>
                                    <DataGridTextColumn Header="Famille" Binding="{Binding ContactTexte}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <TabItem Header="Vaccins / vaccinations">
                <Grid Margin="8" Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Background="#FFFFFF" Margin="4">
                        <TextBlock Text="Catalogue des vaccins" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Label Content="Nom du vaccin"/>
                        <TextBox Text="{Binding NouveauVaccinNom, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding VaccinErrorMessage}" Style="{StaticResource ErrorTextStyle}"/>

                        <Button Content="Ajouter le vaccin" Command="{Binding AjouterVaccinCommand}"/>
                        <Button Content="Supprimer le vaccin sélectionné" Command="{Binding SupprimerVaccinCommand}"/>

                        <TextBlock Text="Vaccination d'un animal" FontSize="18" FontWeight="Bold" Margin="0,18,0,10"/>
                        <Label Content="Animal"/>
                        <ComboBox ItemsSource="{Binding AnimauxPresents}" SelectedItem="{Binding AnimalVaccinationSelectionne}" DisplayMemberPath="NomAvecId"/>
                        <Label Content="Vaccin"/>
                        <ComboBox ItemsSource="{Binding Vaccins}" SelectedItem="{Binding VaccinVaccinationSelectionne}" DisplayMemberPath="NomVaccin"/>
                        <Label Content="Date"/>
                        <DatePicker SelectedDate="{Binding DateVaccination}"/>
                        <CheckBox Content="Vaccin effectué" IsChecked="{Binding VaccinationFaite}" Margin="0,8,0,8"/>
                        <TextBlock Text="{Binding VaccinationErrorMessage}" Style="{StaticResource ErrorTextStyle}"/>

                        <Button Content="Ajouter la vaccination" Command="{Binding AjouterVaccinationCommand}"/>
                        <Button Content="Charger les vaccinations de l'animal" Command="{Binding ChargerVaccinationsCommand}"/>
                    </StackPanel>

                    <TabControl Grid.Column="1" Margin="14,0,0,0" Background="#FFFFFF">
                        <TabItem Header="Vaccins">
                            <DataGrid ItemsSource="{Binding Vaccins}" SelectedItem="{Binding VaccinSelectionne}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding IdVaccin}" Width="Auto"/>
                                    <DataGridTextColumn Header="Nom" Binding="{Binding NomVaccin}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Vaccinations de l'animal">
                            <DataGrid ItemsSource="{Binding VaccinationsAnimal}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding IdVaccination}" Width="Auto"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding DateVaccin, StringFormat=dd/MM/yyyy}" Width="Auto"/>
                                    <DataGridTextColumn Header="Vaccin" Binding="{Binding NomVaccin}" Width="Auto"/>
                                    <DataGridTextColumn Header="État" Binding="{Binding FaitTexte}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>




