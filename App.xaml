<Application x:Class="RefugeAnimaux.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="couchePresentation/Views/MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="BrushBackground" Color="#F5F8FA"/>
        <SolidColorBrush x:Key="BrushSurface" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BrushSurfaceAlt" Color="#EEF6FF"/>
        <SolidColorBrush x:Key="BrushBorder" Color="#D5E2EE"/>
        <SolidColorBrush x:Key="BrushPrimary" Color="#8CBDEB"/>
        <SolidColorBrush x:Key="BrushPrimaryDark" Color="#3F78A8"/>
        <SolidColorBrush x:Key="BrushText" Color="#1B2B34"/>
        <SolidColorBrush x:Key="BrushMuted" Color="#5E6C74"/>

        <Style x:Key="MainWindowStyle" TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BrushBackground}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        </Style>
        <Style TargetType="DockPanel">
            <Setter Property="LastChildFill" Value="True"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="4,8,0,3"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,2,8,8"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,2,8,8"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,2,8,8"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,3,8,3"/>
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        </Style>
        <Style x:Key="ErrorTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B3261E"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,10,8,8"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,5,8,5"/>
            <Setter Property="Background" Value="{StaticResource BrushPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushPrimaryDark}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Background" Value="{StaticResource BrushSurface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E8EFF2"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FBFC"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BrushSurfaceAlt}"/>
            <Setter Property="Foreground" Value="{StaticResource BrushPrimaryDark}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource BrushBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Foreground" Value="{StaticResource BrushMuted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Application.Resources>
</Application>
